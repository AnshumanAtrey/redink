# Generated artifacts (regenerated by /redink-build)
jsons/*.json
output/*.docx
output/*.json
output/qa-report.md

# User's evidence — never commit
poc/web/*/
poc/server/*/
scans/*

# Keep the directory placeholders
!jsons/.gitkeep
!output/.gitkeep
!poc/web/.gitkeep
!poc/server/.gitkeep
!scans/.gitkeep

# Keep example files
!poc/EXAMPLE.md
!frameworks/*/schema.json
!frameworks/*/EXAMPLE.json
!frameworks/*/prompt.md
!frameworks/*/README.md

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Editor
.vscode/
.idea/
.DS_Store

# Logs
*.log
